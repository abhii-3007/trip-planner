// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  admin
  coordinator
}

enum TripStatus {
  upcoming
  ongoing
  completed
  cancelled
}

enum PaymentStatus {
  paid
  pending
  waived
}

// ─── Models ──────────────────────────────────────────────────────────────────

model College {
  id            Int       @id @default(autoincrement())
  name          String
  address       String
  contact_email String    @unique
  students      Student[]
}

model User {
  id            Int    @id @default(autoincrement())
  name          String
  email         String @unique
  password_hash String
  role          Role   @default(coordinator)
  trips         Trip[]
}

model Student {
  id            Int                @id @default(autoincrement())
  name          String
  email         String             @unique
  phone         String
  enrollment_no String             @unique
  department    String
  year          Int
  college_id    Int
  college       College            @relation(fields: [college_id], references: [id])
  created_at    DateTime           @default(now())
  registrations TripRegistration[]

  @@index([college_id])
}

model Trip {
  id           Int                @id @default(autoincrement())
  title        String
  destination  String
  description  String
  start_date   DateTime
  end_date     DateTime
  max_capacity Int
  organizer_id Int
  organizer    User               @relation(fields: [organizer_id], references: [id])
  status       TripStatus         @default(upcoming)
  image_url    String?
  created_at   DateTime           @default(now())
  registrations TripRegistration[]

  @@index([organizer_id])
  @@index([status])
}

model TripRegistration {
  id                Int           @id @default(autoincrement())
  trip_id           Int
  student_id        Int
  trip              Trip          @relation(fields: [trip_id], references: [id], onDelete: Cascade)
  student           Student       @relation(fields: [student_id], references: [id], onDelete: Cascade)
  registered_at     DateTime      @default(now())
  payment_status    PaymentStatus @default(pending)
  emergency_contact String
  medical_notes     String?

  @@unique([trip_id, student_id])
  @@index([trip_id])
  @@index([student_id])
}
